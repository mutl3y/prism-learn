--
-- Name: scan_snapshots; Type: TABLE; Schema: learning; Owner: learning_user
--

CREATE TABLE learning.scan_snapshots (
    id bigint NOT NULL,
    snapshot_uid uuid DEFAULT gen_random_uuid() NOT NULL,
    schema_version integer NOT NULL,
    target_type text NOT NULL,
    target text NOT NULL,
    captured_at_utc timestamp with time zone NOT NULL,
    batch_id bigint,
    scan_payload jsonb NOT NULL,
    role_name text GENERATED ALWAYS AS (COALESCE((scan_payload ->> 'role_name'::text), ''::text)) STORED,
    scanner_counters jsonb GENERATED ALWAYS AS (COALESCE((scan_payload #> '{metadata,scanner_counters}'::text[]), '{}'::jsonb)) STORED,
    created_at timestamp with time zone DEFAULT now() NOT NULL,
    CONSTRAINT scan_snapshots_target_type_check CHECK ((target_type = ANY (ARRAY['role_path'::text, 'repo_url'::text])))
);


ALTER TABLE learning.scan_snapshots OWNER TO learning_user;

--
-- Name: latest_snapshot_per_target; Type: VIEW; Schema: learning; Owner: learning_user
--

CREATE VIEW learning.latest_snapshot_per_target AS
 SELECT DISTINCT ON (target_type, target) id,
    snapshot_uid,
    schema_version,
    target_type,
    target,
    captured_at_utc,
    batch_id,
    role_name,
    scanner_counters,
    scan_payload
   FROM learning.scan_snapshots s
  ORDER BY target_type, target, captured_at_utc DESC;


ALTER VIEW learning.latest_snapshot_per_target OWNER TO learning_user;

