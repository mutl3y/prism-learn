CREATE TABLE learning.scan_batches (
    id bigint NOT NULL,
    batch_uid uuid DEFAULT gen_random_uuid() NOT NULL,
    schema_version integer DEFAULT 1 NOT NULL,
    target_type text NOT NULL,
    run_label text,
    total_targets integer DEFAULT 0 NOT NULL,
    succeeded_targets integer DEFAULT 0 NOT NULL,
    failed_targets integer DEFAULT 0 NOT NULL,
    started_at_utc timestamp with time zone DEFAULT now() NOT NULL,
    finished_at_utc timestamp with time zone,
    metadata jsonb DEFAULT '{}'::jsonb NOT NULL,
    created_at timestamp with time zone DEFAULT now() NOT NULL,
    CONSTRAINT scan_batches_failed_targets_check CHECK ((failed_targets >= 0)),
    CONSTRAINT scan_batches_succeeded_targets_check CHECK ((succeeded_targets >= 0)),
    CONSTRAINT scan_batches_target_type_check CHECK ((target_type = ANY (ARRAY['role_path'::text, 'repo_url'::text]))),
    CONSTRAINT scan_batches_total_targets_check CHECK ((total_targets >= 0))
);


